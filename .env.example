# ═══════════════════════════════════════════════════════════════════════════════
#  AnimeGuesser — Variables d'environnement
#  Copie ce fichier en .env et renseigne chaque valeur
#  Ne commite JAMAIS le fichier .env dans git
# ═══════════════════════════════════════════════════════════════════════════════

# ── Base de données ────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=changeme_root
DB_DATABASE=anime_guesser
DB_USERNAME=animeguesser
DB_PASSWORD=changeme_db

# ── Laravel (backend) ─────────────────────────────────────────────────────────
# Générer avec : php artisan key:generate --show
APP_KEY=base64:REMPLACE_PAR_UNE_VRAIE_CLE_32_OCTETS
APP_DEBUG=false
APP_URL=https://animeguesser.fr

# ── Dashboard admin ────────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme_dashboard
DASHBOARD_PORT=9000

# ── Docker / Réseau ───────────────────────────────────────────────────────────
DOCKER_NETWORK=animeguesser
LB_CONTAINER=animeguesser-lb
LB_PORT=8080

# ── Version server ────────────────────────────────────────────────────────────
# Chemin monté dans le conteneur version-server pour accéder aux releases
RELEASES_DIR=/releases
VERSIONS_DB=/releases/versions.json

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7

# ── Mentions légales (affiché dans les pages légales) ─────────────────────────
# Si micro-entreprise :
LEGAL_NAME=Prénom NOM
LEGAL_ADDRESS=123 rue de la Paix, 75000 Paris, France
LEGAL_SIRET=000 000 000 00000
# Si particulier (sans micro-entreprise) :
# LEGAL_NAME=Prénom NOM (particulier)
# LEGAL_ADDRESS=France
# LEGAL_SIRET=

# ── Contact ────────────────────────────────────────────────────────────────────
CONTACT_EMAIL=contact@animeguesser.fr

# ── Hébergement (mentions légales) ────────────────────────────────────────────
HOSTING_PROVIDER=OVH SAS
HOSTING_ADDRESS=2 rue Kellermann, 59100 Roubaix, France

# ── Réseaux sociaux / Médias ──────────────────────────────────────────────────
# Laisser vide si non applicable
DISCORD_INVITE=https://discord.gg/INVITE_CODE
TWITTER_HANDLE=AnimeGuesser
YOUTUBE_CHANNEL=
TIKTOK_HANDLE=
INSTAGRAM_HANDLE=

# ── Sécurité / CORS ───────────────────────────────────────────────────────────
# En production : remplace * par le domaine exact du dashboard
CORS_ORIGIN=*

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Paris
